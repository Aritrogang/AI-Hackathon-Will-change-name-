# === Katabatic Backend — Environment Variables ===
# Copy this to .env and fill in your keys

# LLM APIs (required for scoring engine + narratives)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# On-chain data (required for Etherscan V2 mint/burn cross-reference)
ETHERSCAN_API_KEY=

# IPFS pinning (required for score verification layer)
PINATA_API_KEY=
PINATA_SECRET_API_KEY=

# Server config
HOST=0.0.0.0
PORT=8000

# NOTE: The following APIs require NO API key:
#   NOAA NWS (api.weather.gov) — User-Agent header only
#   Open-Meteo (archive-api.open-meteo.com) — fully public
#   FDIC BankFind (api.fdic.gov) — fully public
#   Nominatim (nominatim.openstreetmap.org) — User-Agent only
